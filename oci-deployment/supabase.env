# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DE INFRAESTRUTURA OCI - FAZENDA VISTA BELA
# ------------------------------------------------------------------------------
# ATENÇÃO: Altere estes valores para senhas seguras no seu servidor de produção!
# ------------------------------------------------------------------------------

# Senha mestre do Banco de Dados PostgreSQL
POSTGRES_PASSWORD=VistaBela2026SecurePass

# Chave secreta JWT para assinar e validar tokens de login (Mínimo de 32 caracteres)
JWT_SECRET=SuperSecureFarmJWTSecretKey2026WithMoreThan32CharsToAvoidErrors

# ------------------------------------------------------------------------------
# DICAS DE SEGURANÇA 🔐:
# 1. Quando estiver no servidor Linux, você pode gerar uma chave aleatória forte usando:
#    openssl rand -hex 32
# 2. Substitua o valor de JWT_SECRET pelo código gerado para segurança absoluta.
# ------------------------------------------------------------------------------
